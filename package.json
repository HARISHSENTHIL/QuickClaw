{
  "name": "octoclaw-desktop",
  "version": "1.0.1",
  "description": "OctoClaw Desktop Installer",
  "author": "OctoClaw <dev@openledger.xyz>",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "build:mac": "rm -rf dist/mac-* && vite build && electron-builder --mac --universal",
    "build:dev": "rm -rf dist/mac-* && vite build && SKIP_NOTARIZE=1 electron-builder --mac --universal",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^26.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ai.octoclaw.desktop",
    "productName": "OctoClaw",
    "afterSign": "scripts/notarize.js",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "mergeASARs": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "OctoClaw Installer",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "extraResources": [
      {
        "from": "assets/openclaw-install.sh",
        "to": "openclaw-install.sh"
      }
    ],
    "files": [
      "dist/index.html",
      "dist/assets/**",
      "electron/**/*",
      "assets/**/*",
      "!assets/openclaw-install.sh"
    ]
  }
}